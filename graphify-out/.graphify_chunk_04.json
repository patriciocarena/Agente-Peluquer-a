    {"id":"availability_engine_pkg","label":"@turnosbot/availability-engine (shared pure engine)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_compute_slots","label":"computeSlots (pure slot computation)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_book_appointment","label":"bookAppointment (atomic booking write)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_reschedule_appointment","label":"rescheduleAppointment (D-14 UPDATE + self-exclusion)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-01-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Reschedule modeled as UPDATE of the same turno (D-14) instead of cancel+create to preserve turno_id identity/traceability; it excludes the turno's own old slot from the busy set so a small time adjustment doesn't collide with itself, and reuses the bookAppointment 23P01 pattern. Same domain function will be reused by the bot in Phase 6 (BOT-10)."},
    {"id":"concept_skip_booking_window","label":"skipBookingWindow flag (D-08 booking-window bypass)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-01-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Optional flag threaded through ComputeSlotsInput/BookAppointmentInput, default false to preserve bot behavior byte-for-byte; only the dashboard passes true so the owner (D-07) can book 'right now' or beyond 30 days. Keeps a single shared engine (AVAIL-04) instead of a parallel dashboard availability path."},
    {"id":"concept_interval_subtraction","label":"Interval subtraction algorithm (half-open [) intervals)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_grid_snapping","label":"Grid snapping to granularidad (D-01)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Slots always start on multiples of negocio.granularidad_min for a tidy, legible agenda; dead gaps are accepted over squeezing every minute. Anchored to midnight in the negocio timezone rather than shift start."},
    {"id":"concept_auto_assignment","label":"Auto-assignment: earliest available professional (D-03/AVAIL-05)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"When the client has no preference, pick the professional with the earliest free slot to maximize getting an appointment sooner; deterministic tie-break by profesional.id (not load balancing, which was descoped for v1)."},
    {"id":"concept_booking_window","label":"Booking window constants (60min lead / 30 days, D-04/D-05)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_gist_exclude_23p01","label":"GiST EXCLUDE double-booking guard (23P01 → slot_taken)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_snapshot_freezing","label":"Service snapshot freezing at booking (AVAIL-03)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"nombre/precio/duracion frozen into turno_servicio at booking time and summed into turno.precio_total; never a live join to servicio.precio, so later price edits don't rewrite historical appointment totals."},
    {"id":"concept_avail_04_single_engine","label":"AVAIL-04: single shared availability engine","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Exactly one implementation of 'what is free', consumed by both bot and dashboard, so they never disagree. Engine stays pure (data in, slots out) with no embedded Supabase client, working under both service_role and RLS."},
    {"id":"concept_tzdate_timezone","label":"TZDate IANA-aware timezone math","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_tenant_negocio_split","label":"tenant_id→negocio_id drift (tenantScoped→negocioScoped)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/03-motor-de-disponibilidad/03-RESEARCH.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_build_availability_data","label":"buildAvailabilityData (single dashboard fetch helper)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-03-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"One negocio-scoped fetch of the six tables shaped as AvailabilityData, reused by page.tsx and every Server Action, to avoid drift between what the grid shows and what a write revalidates against — the fetch-side analog of AVAIL-04."},
    {"id":"concept_grilla_turnos","label":"GrillaTurnos grid (professionals × hours, D-01/D-02)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-07-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_server_actions_pattern","label":"Server Action pattern (requireRole + getNegocioActivo + RLS + revalidatePath)","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-PATTERNS.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
    {"id":"concept_profesionales_elegibles","label":"profesionalesElegibles (professional×service eligibility gate, Pitfall 6)","file_type":"rationale","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-04-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"computeSlots does not validate whether a professional performs the booked services; profesionalesElegibles filters candidates to those with a profesional_servicio row for ALL requested serviceIds, so alta/reagendar never offers a professional who doesn't do the service."},
    {"id":"concept_popover_component","label":"shadcn Popover primitive","file_type":"concept","source_file":"/Users/augustorinaldi/Agente-Peluqueria/.planning/phases/04-grilla-y-turnos-del-dashboard/04-02-PLAN.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},
