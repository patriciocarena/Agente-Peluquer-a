# TurnosBot — plantilla de variables de entorno (SÍ se commitea; sin valores reales)
# Copiar a .env y completar. El .env real está gitignored.

# Supabase — backend / bot service (service_role BYPASSA RLS; solo servidor)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role key — secreto, nunca en el browser>

# Supabase — dashboard Next.js (RLS; publishable/anon key, segura para el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<publishable / anon key>

# Postgres directo — para migraciones DDL vía Supabase CLI (port 5432, session mode)
SUPABASE_DB_URL=postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres

# Supabase Personal Access Token — para CLI login / Management API (migraciones, gen types)
SUPABASE_ACCESS_TOKEN=<personal access token — Supabase → Account → Access Tokens>
SUPABASE_PROJECT_REF=<project-ref (bdgufnitakelyialjoqg)>

# Gemini (fase 6)
GOOGLE_GENERATIVE_AI_API_KEY=<gemini api key>

# WhatsApp Cloud API — webhook + envío saliente (Fase 5)
WHATSAPP_APP_SECRET=<Meta App Secret — HMAC-SHA256 sobre el body crudo del webhook>
WHATSAPP_VERIFY_TOKEN=<token propio para el handshake GET hub.verify_token>
WHATSAPP_LIVE=false
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_DEV_TOKEN=<token de WhatsApp de prueba, SOLO dev — ver getWhatsappToken.ts D-04>
