{
  "name": "@turnosbot/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TurnosBot — WhatsApp bot service (Fastify webhook/health server)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.8",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@supabase/supabase-js": "^2.110.0",
    "@turnosbot/availability-engine": "workspace:^",
    "@turnosbot/db-types": "workspace:*",
    "ai": "^7.0.16",
    "fastify": "^5.9.0",
    "pg-boss": "^12.25.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "promptfoo": "^0.121.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
